# Orbita — exemplo de configuração
# Copie este arquivo para .env e preencha os valores
# Ou rode: orbita setup

# --- Telegram ---
TELEGRAM_BOT_TOKEN=          # token do @BotFather
TELEGRAM_ALLOWED_USER_ID=    # seu user_id (orbita setup detecta automaticamente)

# --- Backend padrão ---
BOT_DEFAULT_BACKEND=ollama   # ollama | lmstudio

# --- Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# --- LM Studio ---
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
LMSTUDIO_API_TOKEN=
LMSTUDIO_MODEL=qwen3:4b

# --- Windows-MCP (controle da interface gráfica) ---
LMSTUDIO_MCP_MODE=plugin             # plugin | ephemeral | disabled
LMSTUDIO_MCP_PLUGIN_ID=mcp/windows-mcp
LMSTUDIO_MCP_SERVER_URL=
LMSTUDIO_MCP_SERVER_LABEL=windows-mcp
LMSTUDIO_MCP_ALLOWED_TOOLS=Snapshot,Click,Type,Scroll,Move,Shortcut,Wait

# --- Dados em runtime ---
BOT_DATA_DIR=data            # onde ficam memory.json e audit.log
